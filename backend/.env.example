# OpenAI (required for embeddings + generation)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq (required for generation)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# PubMed / retrieval
PUBMED_MAX_RESULTS=15
PUBMED_RETRIEVAL_TOP_K=8
MIN_RELEVANCE_SCORE=0.35
MIN_EVIDENCE_CHUNKS=2

# Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=20

# Logging
LOG_LEVEL=INFO

# Medical safety
BLOCK_EMERGENCY_KEYWORDS=true
MIN_CONFIDENCE_THRESHOLD=0.4

# Set true to skip OpenAI embedding calls (uses local TF-IDF; useful if quota exceeded)
USE_LOCAL_EMBEDDINGS=false
